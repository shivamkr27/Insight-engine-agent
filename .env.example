# ── LLM (required) ────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# Optional fallback providers — system falls back to these if primary is unavailable
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Which provider to use as primary (groq | openai | anthropic)
LLM_PROVIDER=groq
LLM_TIMEOUT_SECONDS=30

# ── Observability (optional) ───────────────────────────────────────────────────
# Get a free key at smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=india-policy-agent

# ── Auth (optional — only activates when CHAINLIT_AUTH_SECRET is set) ─────────
# Generate a secret: python -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Vector store (leave blank to use local ChromaDB) ──────────────────────────
# Set CHROMA_HOST when running with docker-compose (points at chromadb service)
CHROMA_HOST=
CHROMA_PORT=8001

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── File upload ────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
